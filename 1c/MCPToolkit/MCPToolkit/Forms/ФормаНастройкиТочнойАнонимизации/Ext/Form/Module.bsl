&НаСервере
Функция ПодсчитатьВключенныеЛистыНаСервере(СтрокиДерева)

	Количество = 0;
	Для Каждого Строка Из СтрокиДерева Цикл
		Если Строка.ЭтоЛист Тогда
			Если Строка.Использовать = 1 Тогда
				Количество = Количество + 1;
			КонецЕсли;
		Иначе
			Количество = Количество + ПодсчитатьВключенныеЛистыНаСервере(Строка.ПолучитьЭлементы());
		КонецЕсли;
	КонецЦикла;
	Возврат Количество;

