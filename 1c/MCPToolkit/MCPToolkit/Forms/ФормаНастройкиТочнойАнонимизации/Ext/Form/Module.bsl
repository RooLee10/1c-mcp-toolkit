&НаСервереБезКонтекста
Функция ПостроитьПустоеДеревоПравил()

	Дерево = Новый ДеревоЗначений;
	Дерево.Колонки.Добавить("Использовать");
	Дерево.Колонки.Добавить("Представление");
	Дерево.Колонки.Добавить("Анонимизировать");
	Дерево.Колонки.Добавить("ПолноеИмя");
	Дерево.Колонки.Добавить("ЭтоЛист");
	Дерево.Колонки.Добавить("ТипЗначения");
	Дерево.Колонки.Добавить("Картинка");
	Дерево.Колонки.Добавить("ИспользоватьДляСловаря");
	Дерево.Колонки.Добавить("КатегорияТокена");
	Дерево.Колонки.Добавить("КлассТипа");

	Для Каждого ОписаниеКорня Из ПолучитьКорниДереваТочнойАнонимизации() Цикл
		КорневаяСтрока = ДобавитьСтрокуДерева(Дерево.Строки, ОписаниеКорня.Представление, "", Ложь, "");
		КорневаяСтрока.Картинка = КартинкаТипаМетаданных(ОписаниеКорня.Тип);
		Попытка
			КоллекцияМД = Вычислить("Метаданные." + ОписаниеКорня.Коллекция);
		Исключение
			КоллекцияМД = Неопределено;
		КонецПопытки;
		Если КоллекцияМД = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ОбъектМД Из КоллекцияМД Цикл
			Если ОписаниеКорня.Тип = "Константа" Тогда
				Если ЭтоПоддерживаемыйТипПоля(ОбъектМД) Тогда
					НоваяСтрокаЛист = ДобавитьСтрокуДерева(
						КорневаяСтрока.Строки,
						ОбъектМД.Имя,
						"Константа." + ОбъектМД.Имя,
						Истина,
						СтрокаТипаПоля(ОбъектМД));
					НоваяСтрокаЛист.Картинка = КартинкаТипаМетаданных("Константа");
					НоваяСтрокаЛист.КлассТипа = КлассТипаПоля(ОбъектМД);
				КонецЕсли;
			Иначе
				СтрокаОбъекта = ДобавитьСтрокуДерева(
					КорневаяСтрока.Строки,
					ОбъектМД.Имя,
					ОписаниеКорня.Тип + "." + ОбъектМД.Имя,
					Ложь,
					"");
				СтрокаОбъекта.Картинка = КартинкаТипаМетаданных(ОписаниеКорня.Тип);
				ЗаполнитьВеткуОбъектаМетаданных(СтрокаОбъекта, ОбъектМД, ОписаниеКорня.Тип);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Возврат Дерево;

