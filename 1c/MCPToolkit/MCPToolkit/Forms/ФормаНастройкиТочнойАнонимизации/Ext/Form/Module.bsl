Функция ВычислитьСостояниеГруппы(СтрокаДерева)

	ЕстьВключенные = Ложь;
	ЕстьВыключенные = Ложь;
	ЕстьЧастичные = Ложь;

	Для Каждого ПодчиненнаяСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
		Если ПодчиненнаяСтрока.Использовать = 2 Тогда
			ЕстьЧастичные = Истина;
		ИначеЕсли ПодчиненнаяСтрока.Использовать = 1 Тогда
			ЕстьВключенные = Истина;
		Иначе
			ЕстьВыключенные = Истина;
		КонецЕсли;
	КонецЦикла;

	Если ЕстьЧастичные Или (ЕстьВключенные И ЕстьВыключенные) Тогда
		Возврат 2;
	ИначеЕсли ЕстьВключенные Тогда
		Возврат 1;
	КонецЕсли;

	Возврат 0;

