Процедура ОбновитьИсточникНабораНаСервере(ТекстИсточника)
	ИсточникНабораБазовый = ТекстИсточника;
	// При активном фильтре ДеревоПравил урезано — считать по полному набору правил
	Если ПустаяСтрока(ПравилаДоФильтра) Тогда
		Количество = ПодсчитатьВключенныеЛистыНаСервере(ДеревоПравил.ПолучитьЭлементы());
	Иначе
		Количество = СобратьПолныеПравилаДляСохранения().Количество();
	КонецЕсли;
	ИсточникНабора = ТекстИсточника + " (" + Формат(Количество, "ЧГ=0; ЧН=0") + " явных правил"
		+ ?(НЕ ЭтоПроксиРежим И АгрессивнаяАнонимизация, ", агрессивный режим", "") + ")";
