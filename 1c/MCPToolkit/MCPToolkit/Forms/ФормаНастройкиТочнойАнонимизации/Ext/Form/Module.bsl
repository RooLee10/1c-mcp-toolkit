&НаКлиенте
Процедура ФильтрТолькоВСловареПриИзменении(Элемент)
	ОбновитьФильтрДерева();
КонецПроцедуры

&НаКлиенте
Процедура ФильтрАнонимизироватьПриИзменении(Элемент)
	ОбновитьФильтрДерева();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьФильтрДерева()
	ТекстПоиска = СокрЛП(СтрокаПоиска);
	ФильтрАктивен = Не ПустаяСтрока(ТекстПоиска) Или ФильтрТолькоОтмеченные Или ФильтрАнонимизировать <> 0 Или ФильтрТолькоВСловаре;
	Если ФильтрАктивен Тогда
		ОбновитьФильтрДереваНаСервере(ТекстПоиска, ФильтрТолькоОтмеченные, ФильтрАнонимизировать, ФильтрТолькоВСловаре);
	Иначе
		ВосстановитьПолноеДеревоНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьФильтрДереваНаСервере(ТекстПоиска, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре)
	Если ПустаяСтрока(ПравилаДоФильтра) Тогда
		// Первое включение фильтра — сохранить текущие правила как резерв
		ПравилаДоФильтра = ПодготовитьТекстПравилДляФайлаНаСервере();
	Иначе
		// Фильтр уже активен — смержить правки из видимого дерева в резерв перед пересбором
		ОбновитьРезервИзВидимогоДерева();
	КонецЕсли;

	// Пересобрать отфильтрованное дерево из резерва
	ТаблицаПравил = ПрочитатьТаблицуПравилИзТекста(ПравилаДоФильтра);
	ПолноеДерево = ПостроитьДеревоПравилИзТаблицыПравилНаСервере(ТаблицаПравил, "");

	ОтфильтрованноеДерево = Новый ДеревоЗначений;
	ДобавитьКолонкиДереву(ОтфильтрованноеДерево);
	КопироватьПодходящиеВетки(ПолноеДерево.Строки, ОтфильтрованноеДерево.Строки, ВРег(ТекстПоиска), ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре);
	ПересчитатьГруппыВДереве(ОтфильтрованноеДерево.Строки);
	ЗначениеВРеквизитФормы(ОтфильтрованноеДерево, "ДеревоПравил");
КонецПроцедуры

// Мержит правки из текущего видимого дерева в ПравилаДоФильтра
&НаСервере
Процедура ОбновитьРезервИзВидимогоДерева()
	Правила = ПрочитатьТаблицуПравилИзТекста(ПравилаДоФильтра);
	УдалитьОтмененныеВидимыеИзПравил(Правила, ДеревоПравил.ПолучитьЭлементы());
	ВидимыеПравила = СобратьТаблицуПравилИзДереваНаСервере();
	Правила = ОбъединитьТаблицыПравил(Правила, ВидимыеПравила);
	ПравилаДоФильтра = ЗаписатьJSON2(СформироватьJSONПравилКакСтруктуру(Правила));
КонецПроцедуры

// НаСервере — FormDataTree, использует .ПолучитьЭлементы()
// Удаляет из ТаблицаЗначений записи для видимых листьев с Использовать=0
&НаСервере
Процедура УдалитьОтмененныеВидимыеИзПравил(Правила, ЭлементыДерева)
	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл
		Если СтрокаДерева.ЭтоЛист Тогда
			Если СтрокаДерева.Использовать = 0 Тогда
				НайденнаяСтрока = Правила.Найти(СтрокаДерева.ПолноеИмя, "source_path");
				Если НайденнаяСтрока <> Неопределено Тогда
					Правила.Удалить(НайденнаяСтрока);
				КонецЕсли;
			КонецЕсли;
		Иначе
			УдалитьОтмененныеВидимыеИзПравил(Правила, СтрокаДерева.ПолучитьЭлементы());
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// НаСервереБезКонтекста — ДеревоЗначений, использует .Строки
&НаСервереБезКонтекста
Процедура КопироватьПодходящиеВетки(ИсходныеСтроки, ЦелевыеСтроки, ТекстВРег, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре)
	Для Каждого СтрокаДерева Из ИсходныеСтроки Цикл
		Если СтрокаДерева.ЭтоЛист Тогда
			СоответствуетФлагу = Не ТолькоОтмеченные Или СтрокаДерева.Использовать = 1;
			СоответствуетТексту = ПустаяСтрока(ТекстВРег)
				Или Найти(ВРег(СтрокаДерева.Представление), ТекстВРег) > 0
				Или Найти(ВРег(СтрокаДерева.ПолноеИмя), ТекстВРег) > 0;
			СоответствуетАноним = ФильтрАноним = 0
				Или (ФильтрАноним = 1 И СтрокаДерева.Анонимизировать = "Да")
				Или (ФильтрАноним = 2 И СтрокаДерева.Анонимизировать = "Нет")
				Или (ФильтрАноним = 3 И ПустаяСтрока(СтрокаДерева.Анонимизировать));
			СоответствуетСловарю = Не ТолькоВСловаре Или СтрокаДерева.ИспользоватьДляСловаря = Истина;
			Если СоответствуетФлагу И СоответствуетТексту И СоответствуетАноним И СоответствуетСловарю Тогда
				ЗаполнитьЗначенияСвойств(ЦелевыеСтроки.Добавить(), СтрокаДерева);
			КонецЕсли;
		Иначе
			Если ЕстьПодходящиеЛистья(СтрокаДерева.Строки, ТекстВРег, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре) Тогда
				НоваяСтрока = ЦелевыеСтроки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДерева);
				КопироватьПодходящиеВетки(СтрокаДерева.Строки, НоваяСтрока.Строки, ТекстВРег, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЕстьПодходящиеЛистья(СтрокиДерева, ТекстВРег, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре)
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоЛист Тогда
			СоответствуетФлагу = Не ТолькоОтмеченные Или СтрокаДерева.Использовать = 1;
			СоответствуетТексту = ПустаяСтрока(ТекстВРег)
				Или Найти(ВРег(СтрокаДерева.Представление), ТекстВРег) > 0
				Или Найти(ВРег(СтрокаДерева.ПолноеИмя), ТекстВРег) > 0;
			СоответствуетАноним = ФильтрАноним = 0
				Или (ФильтрАноним = 1 И СтрокаДерева.Анонимизировать = "Да")
				Или (ФильтрАноним = 2 И СтрокаДерева.Анонимизировать = "Нет")
				Или (ФильтрАноним = 3 И ПустаяСтрока(СтрокаДерева.Анонимизировать));
			СоответствуетСловарю = Не ТолькоВСловаре Или СтрокаДерева.ИспользоватьДляСловаря = Истина;
			Если СоответствуетФлагу И СоответствуетТексту И СоответствуетАноним И СоответствуетСловарю Тогда Возврат Истина; КонецЕсли;
		Иначе
			Если ЕстьПодходящиеЛистья(СтрокаДерева.Строки, ТекстВРег, ТолькоОтмеченные, ФильтрАноним, ТолькоВСловаре) Тогда Возврат Истина; КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

&НаСервереБезКонтекста
Процедура ДобавитьКолонкиДереву(Дерево)
	Дерево.Колонки.Добавить("Использовать");
	Дерево.Колонки.Добавить("Представление");
	Дерево.Колонки.Добавить("Анонимизировать");
	Дерево.Колонки.Добавить("ПолноеИмя");
	Дерево.Колонки.Добавить("ЭтоЛист");
	Дерево.Колонки.Добавить("ТипЗначения");
	Дерево.Колонки.Добавить("Картинка");
	Дерево.Колонки.Добавить("ИспользоватьДляСловаря", Новый ОписаниеТипов("Булево"));
	Дерево.Колонки.Добавить("КатегорияТокена",        Новый ОписаниеТипов("Строка"));
	Дерево.Колонки.Добавить("КлассТипа",              Новый ОписаниеТипов("Строка"));
КонецПроцедуры

&НаСервере
Процедура ВосстановитьПолноеДеревоНаСервере()
	ОбновитьРезервИзВидимогоДерева();
	ТаблицаПравил = ПрочитатьТаблицуПравилИзТекста(ПравилаДоФильтра);
	Дерево = ПостроитьДеревоПравилИзТаблицыПравилНаСервере(ТаблицаПравил, ИсточникНабораБазовый);
	ЗначениеВРеквизитФормы(Дерево, "ДеревоПравил");
	ОбновитьИсточникНабораНаСервере(ИсточникНабораБазовый);
	ПравилаДоФильтра = "";
КонецПроцедуры

&НаСервере
Процедура СброситьФильтрПередЗагрузкойНаСервере()
	// Если фильтр активен — восстановить полное дерево (мерж правок + пересборка)
	// иначе при merge-импорте увидит урезанное дерево
	Если Не ПустаяСтрока(ПравилаДоФильтра) Тогда
		ВосстановитьПолноеДеревоНаСервере();
	КонецЕсли;
	СтрокаПоиска = "";
	ФильтрТолькоОтмеченные = Ложь;
	ФильтрАнонимизировать = 0;
	ФильтрТолькоВСловаре = Ложь;
КонецПроцедуры

// Возвращает полный набор правил независимо от активности фильтра
&НаСервере
Функция СобратьПолныеПравилаДляСохранения()
	Если ПустаяСтрока(ПравилаДоФильтра) Тогда
		Возврат СобратьТаблицуПравилИзДереваНаСервере();
	КонецЕсли;
	Правила = ПрочитатьТаблицуПравилИзТекста(ПравилаДоФильтра);
	УдалитьОтмененныеВидимыеИзПравил(Правила, ДеревоПравил.ПолучитьЭлементы());
	ВидимыеПравила = СобратьТаблицуПравилИзДереваНаСервере();
	Возврат ОбъединитьТаблицыПравил(Правила, ВидимыеПравила);
КонецФункции

&НаКлиенте
Процедура УстановитьФлаги(Команда)
	Если МодальностьЗапрещена() Тогда
		ПоказатьВопрос(
			Новый ОписаниеОповещения("УстановитьФлагиПослеВопроса", ЭтаФорма),
			"Установить все отметки?",
			РежимДиалогаВопрос.ДаНет);
	Иначе
		УстановитьФлагиПослеВопроса(
			Вопрос("Установить все отметки?", РежимДиалогаВопрос.ДаНет), Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФлагиПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	УстановитьФлагиНаСервере();
	ЕстьНесохраненныеИзменения = Истина;
КонецПроцедуры

&НаСервере
Процедура УстановитьФлагиНаСервере()
	УстановитьФлагиВСтроках(ДеревоПравил.ПолучитьЭлементы());
	Если Не ПустаяСтрока(ПравилаДоФильтра) Тогда
		ОбновитьРезервИзВидимогоДерева();
	КонецЕсли;
	ОбновитьИсточникНабораНаСервере(ИсточникНабораБазовый);
КонецПроцедуры

&НаСервере
Процедура УстановитьФлагиВСтроках(СтрокиДерева)
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоЛист Тогда
			СтрокаДерева.Использовать = 1;
			Если Не ЗначениеЗаполнено(СтрокаДерева.Анонимизировать) Тогда
				СтрокаДерева.Анонимизировать = "Да";
			КонецЕсли;
		Иначе
			УстановитьФлагиВСтроках(СтрокаДерева.ПолучитьЭлементы());
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьВсеФлаги(Команда)
	Если МодальностьЗапрещена() Тогда
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОчиститьВсеФлагиПослеВопроса", ЭтаФорма),
			"Снять все отметки?",
			РежимДиалогаВопрос.ДаНет);
	Иначе
		ОчиститьВсеФлагиПослеВопроса(
			Вопрос("Снять все отметки?", РежимДиалогаВопрос.ДаНет), Неопределено);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьВсеФлагиПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	ОчиститьВсеФлагиНаСервере();
	ЕстьНесохраненныеИзменения = Истина;
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьВсе(Команда)
	РазвернутьСвернутьДерево(ДеревоПравил.ПолучитьЭлементы(), Истина);
КонецПроцедуры

&НаКлиенте
Процедура СвернутьВсе(Команда)
	// Платформа не сворачивает ветку с выделенной строкой.
	// Переносим выделение на первый корневой элемент — он видим даже в свёрнутом дереве.
	КорневыеЭлементы = ДеревоПравил.ПолучитьЭлементы();
	Если КорневыеЭлементы.Количество() > 0 Тогда
		Элементы.ТаблицаДеревоПравил.ТекущаяСтрока = КорневыеЭлементы[0].ПолучитьИдентификатор();
	КонецЕсли;
	РазвернутьСвернутьДерево(КорневыеЭлементы, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьСвернутьДерево(ЭлементыДерева, Развернуть)
	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл
		Если Не СтрокаДерева.ЭтоЛист Тогда
			Если Развернуть Тогда
				Элементы.ТаблицаДеревоПравил.Развернуть(СтрокаДерева.ПолучитьИдентификатор(), Ложь);
				РазвернутьСвернутьДерево(СтрокаДерева.ПолучитьЭлементы(), Развернуть);
			Иначе
				// При сворачивании — сначала рекурсивно свернуть детей, потом родителя
				РазвернутьСвернутьДерево(СтрокаДерева.ПолучитьЭлементы(), Развернуть);
				Элементы.ТаблицаДеревоПравил.Свернуть(СтрокаДерева.ПолучитьИдентификатор());
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОчиститьВсеФлагиНаСервере()
	// Чистим только видимые строки (с учётом фильтра)
	ОчиститьФлагиВСтроках(ДеревоПравил.ПолучитьЭлементы());
	// Если фильтр активен — мержим изменения в резерв, фильтр остаётся
	Если Не ПустаяСтрока(ПравилаДоФильтра) Тогда
		ОбновитьРезервИзВидимогоДерева();
	КонецЕсли;
	ОбновитьИсточникНабораНаСервере(ИсточникНабораБазовый);
КонецПроцедуры

&НаСервере
Процедура ОчиститьФлагиВСтроках(СтрокиДерева)
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		СтрокаДерева.Использовать = 0;
		Если СтрокаДерева.ЭтоЛист Тогда
			СтрокаДерева.Анонимизировать = "";
		КонецЕсли;
		Если СтрокаДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			ОчиститьФлагиВСтроках(СтрокаДерева.ПолучитьЭлементы());
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

