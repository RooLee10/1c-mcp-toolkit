&НаКлиентеНаСервереБезКонтекста
Функция ОпределитьКатегориюТокенаЛокально(ПолноеИмяПоля)

	Сегменты = Новый Массив;
	ОстатокПути = ПолноеИмяПоля;
	Пока Истина Цикл
		Поз = Найти(ОстатокПути, ".");
		Если Поз = 0 Тогда
			Сегменты.Добавить(ОстатокПути);
			Прервать;
		КонецЕсли;
		Сегменты.Добавить(Лев(ОстатокПути, Поз - 1));
		ОстатокПути = Сред(ОстатокПути, Поз + 1);
	КонецЦикла;

	ИмяПоля = ВРег(Сегменты[Сегменты.ВГраница()]);

	Если ИмяПоля = "ИНН"                               Тогда Возврат "INN";      КонецЕсли;
	Если ИмяПоля = "КПП"                               Тогда Возврат "KPP";      КонецЕсли;
	Если ИмяПоля = "ОГРН" Или ИмяПоля = "ОГРНИП"      Тогда Возврат "OGRN";     КонецЕсли;
	Если ИмяПоля = "СНИЛС"                             Тогда Возврат "SNILS";    КонецЕсли;
	Если ИмяПоля = "БИК"                               Тогда Возврат "BIK";      КонецЕсли;
	Если ИмяПоля = "СЧЕТ"                              Тогда Возврат "ACC";      КонецЕсли;
	Если ИмяПоля = "АВТОР"           Или ИмяПоля = "ОТВЕТСТВЕННЫЙ" Или ИмяПоля = "ИСПОЛНИТЕЛЬ"
	  Или ИмяПоля = "ИЗМЕНИЛ"        Или ИмяПоля = "РЕДАКТОР"      Или ИмяПоля = "РЕДАКТИРУЕТ"
	  Или ИмяПоля = "ФАМИЛИЯ"        Или ИмяПоля = "ОТЧЕСТВО"
	  Или ИмяПоля = "ФИЗИЧЕСКОЕЛИЦО" Или ИмяПоля = "ФИЗЛИЦО"       Или ИмяПоля = "ФИО"           Тогда Возврат "PER"; КонецЕсли;
	Если ИмяПоля = "СТРАНА"          Или ИмяПоля = "ГОРОД"         Или ИмяПоля = "УЛИЦА"
	  Или ИмяПоля = "ДОМ"            Или ИмяПоля = "КВАРТИРА"                                     Тогда Возврат "LOC"; КонецЕсли;
	Если Найти(ИмяПоля, "ТЕЛЕФОН")     > 0 Или Найти(ИмяПоля, "PHONE")      > 0 Тогда Возврат "PHONE";    КонецЕсли;
	Если Найти(ИмяПоля, "EMAIL")       > 0 Или Найти(ИмяПоля, "ПОЧТА")      > 0 Тогда Возврат "EMAIL";    КонецЕсли;
	Если Найти(ИмяПоля, "ПАСПОРТ")     > 0 Или Найти(ИмяПоля, "PASSPORT")   > 0 Тогда Возврат "PASSPORT"; КонецЕсли;
	Если Найти(ИмяПоля, "ДАТА")        > 0 Или Найти(ИмяПоля, "DATE")       > 0 Тогда Возврат "DATE";     КонецЕсли;
	Если Найти(ИмяПоля, "АДРЕС")       > 0 Или Найти(ИмяПоля, "ADDRESS")    > 0 Тогда Возврат "LOC";      КонецЕсли;
	Если Найти(ИмяПоля, "РАСЧЕТНЫЙ")   > 0                                       Тогда Возврат "ACC";      КонецЕсли;
	Если Найти(ИмяПоля, "ОРГАНИЗАЦИЯ") > 0 Или Найти(ИмяПоля, "КОНТРАГЕНТ") > 0
	  Или Найти(ИмяПоля, "PARTNER")    > 0                                       Тогда Возврат "ORG";      КонецЕсли;
	Если Найти(ИмяПоля, "ФИЗЛИЦО")     > 0 Или Найти(ИмяПоля, "СОТРУДНИК")  > 0
	  Или Найти(ИмяПоля, "PERSON")     > 0                                       Тогда Возврат "PER";      КонецЕсли;

	Если Сегменты.Количество() >= 2 Тогда
		ИмяОбъекта = ВРег(Сегменты[1]);
		Если Найти(ИмяОбъекта, "ФИЗЛИЦ")       > 0
		  Или Найти(ИмяОбъекта, "СОТРУДНИК")   > 0
		  Или Найти(ИмяОбъекта, "PERSON")      > 0 Тогда
			Возврат "PER";
		КонецЕсли;
		Если Найти(ИмяОбъекта, "КОНТРАГЕНТ")   > 0
		  Или Найти(ИмяОбъекта, "ОРГАНИЗАЦИЯ") > 0
		  Или Найти(ИмяОбъекта, "PARTNER")     > 0 Тогда
			Возврат "ORG";
		КонецЕсли;
	КонецЕсли;

	Возврат "STR";

КонецФункции

