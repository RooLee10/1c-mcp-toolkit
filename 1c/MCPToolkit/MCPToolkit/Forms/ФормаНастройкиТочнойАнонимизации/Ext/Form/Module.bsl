&НаКлиенте
Перем ЗакрытиеБезПодтверждения;

&НаКлиенте
Перем ЗакрытьПослеСохранения; // Истина если сохранение вызвано из ПередЗакрытием

&НаКлиенте
Перем БылиСохраненыИзменения; // Истина если в эту сессию было успешное сохранение

&НаКлиенте
Перем КомпонентаRegexВалид; // собственный экземпляр RegexHelper для валидации паттернов

// ─────────────────────────────────────────────────────────────────────────────────
// ЖИЗНЕННЫЙ ЦИКЛ ФОРМЫ
// ─────────────────────────────────────────────────────────────────────────────────

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЕстьНесохраненныеИзменения = Ложь;

	// Режим подключения: 0 = прокси, 1 = встроенный сервер (по умолчанию)
	// Читаем первым, чтобы ОбновитьИсточникНабораНаСервере уже знал режим
	ЭтоПроксиРежим = Параметры.Свойство("РежимПодключения")
		И Параметры.РежимПодключения = 0;

	ОписаниеНабора = ПолучитьНачальныйНаборПравил();
	ЗначениеВРеквизитФормы(ОписаниеНабора.Дерево, "ДеревоПравил");
	АгрессивнаяАнонимизация = ОписаниеНабора.АгрессивнаяАнонимизация;
	ОбновитьИсточникНабораНаСервере(ОписаниеНабора.Источник);

	// Загрузить regex-правила
	ЗагрузитьRegexПравилаВТаблицуНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	БылиСохраненыИзменения   = Ложь;
	ЗакрытиеБезПодтверждения = Ложь;
	ЗакрытьПослеСохранения   = Ложь;
	УстановитьВидимостьЭлементовПоРежиму(ЭтоПроксиРежим);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьЭлементовПоРежиму(ЭтоПрокси)
	Элементы.ФлагАгрессивнаяАнонимизация.Видимость        = НЕ ЭтоПрокси;
	Элементы.НадписьРазделитель.Видимость                 = НЕ ЭтоПрокси;
	Элементы.КнопкаТолькоВСловаре.Видимость               = НЕ ЭтоПрокси;
	Элементы.ДеревоПравилИспользоватьДляСловаря.Видимость = НЕ ЭтоПрокси;
	Элементы.ДеревоПравилКатегорияТокена.Видимость        = НЕ ЭтоПрокси;
	Элементы.ГруппаRegexПравил.Видимость                  = НЕ ЭтоПрокси;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ)

	Если ЗакрытиеБезПодтверждения = Истина Тогда
		Возврат; // повторный вход после явного Закрыть() — пропускаем
	КонецЕсли;

	Отказ = Истина; // блокируем естественное закрытие платформой

	Если Не ЕстьНесохраненныеИзменения Тогда
		// Нет несохранённых изменений — закрываем с флагом сохранения
		ЗакрытиеБезПодтверждения = Истина;
		Закрыть(БылиСохраненыИзменения);
		Возврат;
	КонецЕсли;

	Если МодальностьЗапрещена() Тогда
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ПередЗакрытиемПослеВопроса", ЭтаФорма),
			"Сохранить изменения?",
			РежимДиалогаВопрос.ДаНетОтмена);
	Иначе
		ПередЗакрытиемПослеВопроса(
			Вопрос("Сохранить изменения?", РежимДиалогаВопрос.ДаНетОтмена), Неопределено);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		// Делегируем полную логику валидации в Сохранить; после сохранения — закрыть
		ЗакрытьПослеСохранения = Истина;
		Сохранить(Неопределено);
		// Закроется из ЗавершитьСохранение() с Закрыть(Истина)
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		// Пользователь отказался сохранять, но сохранения могли быть раньше в этой сессии
		ЗакрытиеБезПодтверждения = Истина;
		Закрыть(БылиСохраненыИзменения);
	КонецЕсли;
	// Отмена — ничего не делаем, Отказ = Истина уже стоит
КонецПроцедуры

// ─────────────────────────────────────────────────────────────────────────────────
// КОМАНДЫ ФОРМЫ
// ─────────────────────────────────────────────────────────────────────────────────

&НаКлиенте
Процедура Сохранить(Команда)

	МассивПаттернов = СобратьУникальныеПаттерны();

	Если МассивПаттернов.Количество() = 0 Тогда
		// Нет паттернов — сохранять без проверки
		ЗавершитьСохранение();
		Возврат;
	КонецЕсли;

	// Есть паттерны — нужна валидация; lazy-load если компонента ещё не загружена
	Если КомпонентаRegexВалид = Неопределено Тогда
		Если ИспользоватьАсинхронноеПодключениеКомпонент Тогда
			НачатьАсинхронноеПодключениеКомпоненты(
				Новый ОписаниеОповещения("ПослеЗагрузкиRegexВалидДляСохранения", ЭтаФорма, МассивПаттернов),
				"ВнешняяОбработка.MCPToolkit.Макет.RegexHelper", "RegexH");
			Возврат;
		Иначе
			ПодключитьКомпонентуRegexВалидСинхронно();
		КонецЕсли;
	КонецЕсли;

	Если КомпонентаRegexВалид = Неопределено Тогда
		// Компонент недоступен — сохранять без проверки
		ЗавершитьСохранение();
		Возврат;
	КонецЕсли;

	// Компонент загружен — валидировать
	Если ИспользоватьАсинхронноеПодключениеКомпонент Тогда
		НачатьВалидациюПаттернаДляСохранения(0, МассивПаттернов);
	Иначе
		Для Каждого Паттерн Из МассивПаттернов Цикл
			Ошибка = КомпонентаRegexВалид.ПроверитьШаблон(Паттерн);
			Если НЕ ПустаяСтрока(Ошибка) Тогда
				ПоказатьПредупреждение(, "Невалидный regex-паттерн: """ + Паттерн + """" + Символы.ПС + Ошибка);
				ЗакрытьПослеСохранения = Ложь; // сброс флага — не закрывать при ошибке
				Возврат;
			КонецЕсли;
		КонецЦикла;
		ЗавершитьСохранение();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьСохранение()
	СохранитьИОбновитьИсточникНаСервере();
	Если ЕстьНесохраненныеИзменения Тогда
		БылиСохраненыИзменения = Истина;
	КонецЕсли;
	ЕстьНесохраненныеИзменения = Ложь;
	Если ЗакрытьПослеСохранения = Истина Тогда
		ЗакрытьПослеСохранения = Ложь;
		ЗакрытиеБезПодтверждения = Истина;
		Закрыть(БылиСохраненыИзменения);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(Команда)

	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьНастройкиПоУмолчанию(Команда)

	ЗагрузитьНастройкиПоУмолчаниюНаСервере();
	ЕстьНесохраненныеИзменения = Истина;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройкиПоУмолчаниюНаСервере()
	СброситьФильтрПередЗагрузкойНаСервере();

	Дерево = ПостроитьДеревоПравилИзТаблицыПравилНаСервере(
		ПолучитьТаблицуПравилПоУмолчаниюНаСервере(),
		"Настройки по умолчанию");
	ЗначениеВРеквизитФормы(Дерево, "ДеревоПравил");
	АгрессивнаяАнонимизация = Ложь;
	ОбновитьИсточникНабораНаСервере("Настройки по умолчанию");

	// Сбросить regex-правила к дефолтным
	ЗагрузитьRegexПравилаПоУмолчаниюНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.ПолноеИмяФайла = "";
	Диалог.Фильтр = "Настройки (*.json;*.xml)|*.json;*.xml|Все файлы (*.*)|*.*";

	Если Не Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	ДопПараметры = Новый Структура("ПолноеИмяФайла", Диалог.ПолноеИмяФайла);
	Если МодальностьЗапрещена() Тогда
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ЗагрузитьИзФайлаПослеВопроса", ЭтаФорма, ДопПараметры),
			"Заменить текущие настройки? Нажмите Да для замены, Нет для объединения.",
			РежимДиалогаВопрос.ДаНетОтмена);
	Иначе
		ЗагрузитьИзФайлаПослеВопроса(
			Вопрос("Заменить текущие настройки? Нажмите Да для замены, Нет для объединения.",
				РежимДиалогаВопрос.ДаНетОтмена),
			ДопПараметры);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайлаПослеВопроса(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;

	РежимЗагрузки = ?(РезультатВопроса = КодВозвратаДиалога.Да, "replace", "merge");

	Попытка
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.Прочитать(ДополнительныеПараметры.ПолноеИмяФайла);
		ТекстНастроек = ТекстовыйДокумент.ПолучитьТекст();
	Исключение
		ПоказатьПредупреждение(, "Не удалось прочитать файл: " + ОписаниеОшибки());
		Возврат;
	КонецПопытки;

	Попытка
		Сообщение = ЗагрузитьИзФайлаВФормуНаСервере(
			ТекстНастроек,
			РежимЗагрузки);
		ЕстьНесохраненныеИзменения = Истина;
		Если Не ПустаяСтрока(Сообщение) Тогда
			ПоказатьПредупреждение(, Сообщение);
		КонецЕсли;
	Исключение
		ПоказатьПредупреждение(, ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура СохранитьВФайл(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.ПолноеИмяФайла = "execute_query_field_rules.json";
	Диалог.Фильтр = "JSON (*.json)|*.json|Все файлы (*.*)|*.*";

	Если Не Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	ТекстДляФайла = ПодготовитьТекстПравилДляФайлаНаСервере();

	Попытка
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.УстановитьТекст(ТекстДляФайла);
		ТекстовыйДокумент.Записать(Диалог.ПолноеИмяФайла);
	Исключение
		ПоказатьПредупреждение(, "Не удалось сохранить файл: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоПравилИспользоватьПриИзменении(Элемент)

	СтрокаДерева = ПолучитьТекущуюСтрокуДерева(Элемент);
	Если СтрокаДерева = Неопределено Тогда
		Возврат;
	КонецЕсли;

	// При активном фильтре изменение группы затронет только видимых потомков —
	// скрытые останутся нетронутыми, что даёт неверный результат после снятия фильтра.
	// Блокируем групповое редактирование; листы редактируются свободно.
	Если (Не ПустаяСтрока(СокрЛП(СтрокаПоиска)) Или ФильтрТолькоОтмеченные Или ФильтрАнонимизировать <> 0 Или ФильтрТолькоВСловаре)
		И Не СтрокаДерева.ЭтоЛист Тогда
		СтрокаДерева.Использовать = ВычислитьСостояниеГруппы(СтрокаДерева);
		Возврат;
	КонецЕсли;

	// Узел может принять значение 2 (серый) при триstate-цикле платформы — нормализуем до 0/1
	НовоеСостояние = ?(СтрокаДерева.Использовать = 1, 1, 0);
	СтрокаДерева.Использовать = НовоеСостояние;
	Если Не СтрокаДерева.ЭтоЛист Тогда
		УстановитьИспользованиеДляПодчиненных(СтрокаДерева, НовоеСостояние);
	Иначе
		Если НовоеСостояние = 1 И Не ЗначениеЗаполнено(СтрокаДерева.Анонимизировать) Тогда
			СтрокаДерева.Анонимизировать = "Да";
		ИначеЕсли НовоеСостояние = 0 Тогда
			СтрокаДерева.Анонимизировать = "";
		КонецЕсли;
		Если НовоеСостояние = 1 И ПустаяСтрока(СтрокаДерева.КатегорияТокена) Тогда
			СтрокаДерева.КатегорияТокена = ОпределитьКатегориюТокенаЛокально(СтрокаДерева.ПолноеИмя);
		КонецЕсли;
	КонецЕсли;

	ПересчитатьРодителей(СтрокаДерева);
	ЕстьНесохраненныеИзменения = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоПравилАнонимизироватьПриИзменении(Элемент)

	СтрокаДерева = ПолучитьТекущуюСтрокуДерева(Элемент);
	Если СтрокаДерева = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Не СтрокаДерева.ЭтоЛист Тогда
		СтрокаДерева.Анонимизировать = "";
		Возврат;
	КонецЕсли;

	СтрокаДерева.Использовать = 1;
	СтрокаДерева.Анонимизировать = НормализоватьДействиеПоля(СтрокаДерева.Анонимизировать);
	ПересчитатьРодителей(СтрокаДерева);
	ЕстьНесохраненныеИзменения = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоПравилИспользоватьДляСловаряПриИзменении(Элемент)

	СтрокаДерева = ПолучитьТекущуюСтрокуДерева(Элемент);
	Если СтрокаДерева = Неопределено Или Не СтрокаДерева.ЭтоЛист Или СтрокаДерева.Использовать <> 1 Тогда
		Если СтрокаДерева <> Неопределено Тогда
			СтрокаДерева.ИспользоватьДляСловаря = Ложь;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	ЕстьНесохраненныеИзменения = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ДеревоПравилКатегорияТокенаПриИзменении(Элемент)

	СтрокаДерева = ПолучитьТекущуюСтрокуДерева(Элемент);
	Если СтрокаДерева = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Не СтрокаДерева.ЭтоЛист Тогда
		СтрокаДерева.КатегорияТокена = "";
		Возврат;
	КонецЕсли;

	СтрокаДерева.КатегорияТокена = ВРег(СтрокаДерева.КатегорияТокена);
	ЕстьНесохраненныеИзменения = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ФлагАгрессивнаяАнонимизацияПриИзменении(Элемент)
	ЕстьНесохраненныеИзменения = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоПравилПриАктивизацииСтроки(Элемент)

	СтрокаДерева = ПолучитьТекущуюСтрокуДерева(Элемент);
	ЭтоЛист = (СтрокаДерева <> Неопределено) И СтрокаДерева.ЭтоЛист;
	Элементы.ДеревоПравилКатегорияТокена.ТолькоПросмотр = Не ЭтоЛист;
	Элементы.ДеревоПравилАнонимизировать.ТолькоПросмотр = Не ЭтоЛист;

КонецПроцедуры

// ─────────────────────────────────────────────────────────────────────────────────
// КЛИЕНТСКОЕ ДЕРЕВО ПРАВИЛ
// ─────────────────────────────────────────────────────────────────────────────────

&НаКлиенте
Функция ПолучитьТекущуюСтрокуДерева(Элемент)

	Попытка
		Если Элементы.ТаблицаДеревоПравил.ТекущиеДанные <> Неопределено Тогда
			Возврат Элементы.ТаблицаДеревоПравил.ТекущиеДанные;
		КонецЕсли;
	Исключение
	КонецПопытки;

	Попытка
		Возврат Элемент.ТекущиеДанные;
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

&НаКлиенте
Процедура УстановитьИспользованиеДляПодчиненных(СтрокаДерева, Использовать)

	Для Каждого ПодчиненнаяСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
		ПодчиненнаяСтрока.Использовать = Использовать;
		Если ПодчиненнаяСтрока.ЭтоЛист Тогда
			Если Использовать = 1 Тогда
				Если Не ЗначениеЗаполнено(ПодчиненнаяСтрока.Анонимизировать) Тогда
					ПодчиненнаяСтрока.Анонимизировать = "Да";
				КонецЕсли;
			Иначе
				ПодчиненнаяСтрока.Анонимизировать = "";
			КонецЕсли;
		Иначе
			УстановитьИспользованиеДляПодчиненных(ПодчиненнаяСтрока, Использовать);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьРодителей(СтрокаДерева)

	РодительСтроки = ПолучитьРодителяСтроки(СтрокаДерева);
	Пока РодительСтроки <> Неопределено Цикл
		РодительСтроки.Использовать = ВычислитьСостояниеГруппы(РодительСтроки);
		РодительСтроки = ПолучитьРодителяСтроки(РодительСтроки);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Функция ПолучитьРодителяСтроки(СтрокаДерева)

	Попытка
