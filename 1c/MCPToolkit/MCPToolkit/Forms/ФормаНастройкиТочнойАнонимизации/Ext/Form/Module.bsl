&НаКлиенте
Процедура ТаблицаRegexПравилШаблонПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	Если ОтменаРедактирования Тогда Возврат; КонецЕсли;
	ТекущаяСтрока = Элементы.ТаблицаRegexПравил.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда Возврат; КонецЕсли;
	Шаблон = ТекущаяСтрока.Шаблон;
	Если ПустаяСтрока(Шаблон) Тогда Возврат; КонецЕсли;

	Если ИспользоватьАсинхронноеПодключениеКомпонент Тогда
		// Async-путь
		Если КомпонентаRegexВалид <> Неопределено Тогда
			КомпонентаRegexВалид.НачатьВызовValidatePattern(
				Новый ОписаниеОповещения("ПослеПроверкиПаттерна", ЭтаФорма, Шаблон), Шаблон);
		Иначе
			НачатьАсинхронноеПодключениеКомпоненты(
				Новый ОписаниеОповещения("ПослеЗагрузкиРегексВалидМакетРед", ЭтаФорма, Шаблон),
				"ВнешняяОбработка.MCPToolkit.Макет.RegexHelper", "RegexH");
		КонецЕсли;
	Иначе
		// Sync-путь
		Если КомпонентаRegexВалид = Неопределено Тогда
			ПодключитьКомпонентуRegexВалидСинхронно();
		КонецЕсли;
		Если КомпонентаRegexВалид = Неопределено Тогда Возврат; КонецЕсли;
		Ошибка = КомпонентаRegexВалид.ПроверитьШаблон(Шаблон);
		Если НЕ ПустаяСтрока(Ошибка) Тогда
			ПоказатьПредупреждение(, "Невалидный regex: """ + Шаблон + """" + Символы.ПС + Ошибка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

