		ЗакрытьПослеСохранения = Ложь; // сброс флага — не закрывать при ошибке
		Возврат; // не сохранять
	КонецЕсли;
	НачатьВалидациюПаттернаДляСохранения(ДопПар.Индекс + 1, ДопПар.Массив);
