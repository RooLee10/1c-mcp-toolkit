			ДвоичныеДанные = ПолучитьМакетRegexВалидНаСервере();
			ВремФайл = ПолучитьИмяВременногоФайла("dll");
			ДвоичныеДанные.Записать(ВремФайл);
			ПодключитьВнешнююКомпоненту(ВремФайл, "RegexH", ТипВнешнейКомпоненты.Native);
		КонецЕсли;
		КомпонентаRegexВалид = Новый("AddIn.RegexH.RegexHelper");
