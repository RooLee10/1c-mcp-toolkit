&НаСервереБезКонтекста
Функция ЗагрузитьПравилаИзБазыНаСервере()

	// Пробуем v2
	Попытка
		ЗначениеНастроек = ХранилищеОбщихНастроек.Загрузить("MCPToolkit", "ExecuteQueryFieldRules.v2");
		Если ТипЗнч(ЗначениеНастроек) = Тип("Структура") И ЗначениеНастроек.Свойство("Правила") Тогда
			Возврат ЗначениеНастроек;
		КонецЕсли;
	Исключение
	КонецПопытки;

	// Fallback v1 → мигрируем на v2-структуру таблицы
	Попытка
		ЗначениеНастроекV1 = ХранилищеОбщихНастроек.Загрузить("MCPToolkit", "ExecuteQueryFieldRules.v1");
		Если ЗначениеНастроекV1 = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		Если ТипЗнч(ЗначениеНастроекV1) = Тип("Структура") И ЗначениеНастроекV1.Свойство("Правила") Тогда
			ТаблицаV2 = СоздатьТаблицуПравил();
			Для Каждого СтрокаV1 Из ЗначениеНастроекV1.Правила Цикл
				НоваяСтрока = ТаблицаV2.Добавить();
				НоваяСтрока.source_path = СтрокаV1.source_path;
				НоваяСтрока.action = СтрокаV1.action;
				НоваяСтрока.match_kind = СтрокаV1.match_kind;
				НоваяСтрока.use_for_dictionary = Ложь;
				НоваяСтрока.token_category = "";
			КонецЦикла;
			Возврат Новый Структура("Версия, Правила", 2, ТаблицаV2);
		КонецЕсли;
	Исключение
	КонецПопытки;

	Возврат Неопределено;

КонецФункции

