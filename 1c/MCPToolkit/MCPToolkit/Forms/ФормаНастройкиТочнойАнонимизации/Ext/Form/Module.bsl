&НаСервереБезКонтекста
Функция КартинкаТипаМетаданных(ТипМетаданных)

	Если ТипМетаданных = "Константа" Тогда
		Возврат БиблиотекаКартинок.Константа;
	ИначеЕсли ТипМетаданных = "Справочник" Тогда
		Возврат БиблиотекаКартинок.Справочник;
	ИначеЕсли ТипМетаданных = "Документ" Тогда
		Возврат БиблиотекаКартинок.Документ;
	ИначеЕсли ТипМетаданных = "ПланВидовХарактеристик" Тогда
		Возврат БиблиотекаКартинок.ПланВидовХарактеристик;
	ИначеЕсли ТипМетаданных = "ПланСчетов" Тогда
		Возврат БиблиотекаКартинок.ПланСчетов;
	ИначеЕсли ТипМетаданных = "ПланВидовРасчета" Тогда
		Возврат БиблиотекаКартинок.ПланВидовРасчета;
	ИначеЕсли ТипМетаданных = "РегистрСведений" Тогда
		Возврат БиблиотекаКартинок.РегистрСведений;
	ИначеЕсли ТипМетаданных = "РегистрНакопления" Тогда
		Возврат БиблиотекаКартинок.РегистрНакопления;
	ИначеЕсли ТипМетаданных = "РегистрБухгалтерии" Тогда
		Возврат БиблиотекаКартинок.РегистрБухгалтерии;
	ИначеЕсли ТипМетаданных = "РегистрРасчета" Тогда
		Возврат БиблиотекаКартинок.РегистрРасчета;
	ИначеЕсли ТипМетаданных = "БизнесПроцесс" Тогда
		Возврат БиблиотекаКартинок.БизнесПроцесс;
	ИначеЕсли ТипМетаданных = "Задача" Тогда
		Возврат БиблиотекаКартинок.Задача;
	КонецЕсли;

	Возврат Новый Картинка;

КонецФункции

&НаСервереБезКонтекста
Функция КартинкаКоллекции(ИмяКоллекции)

	Если ИмяКоллекции = "Измерения" Тогда
		Возврат БиблиотекаКартинок.Измерение;
	ИначеЕсли ИмяКоллекции = "Ресурсы" Тогда
		Возврат БиблиотекаКартинок.Ресурс;
	КонецЕсли;

	Возврат БиблиотекаКартинок.Реквизит;

КонецФункции

&НаСервереБезКонтекста
Процедура ЗаполнитьВеткуОбъектаМетаданных(СтрокаОбъекта, ОбъектМД, ТипКорня)

	Если ТипКорня = "РегистрСведений" Или ТипКорня = "РегистрНакопления"
		Или ТипКорня = "РегистрБухгалтерии" Или ТипКорня = "РегистрРасчета" Тогда
		ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "Измерения", "Измерения");
		ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "Ресурсы", "Ресурсы");
		ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "Реквизиты", "Реквизиты");
		Возврат;
	КонецЕсли;

	ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "СтандартныеРеквизиты", "Стандартные реквизиты");
	ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "Реквизиты", "Реквизиты");
	Если ТипКорня = "Задача" Тогда
		ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, "РеквизитыАдресации", "Реквизиты адресации");
	КонецЕсли;
	ДобавитьТабличныеЧасти(СтрокаОбъекта, ОбъектМД, ТипКорня);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьКоллекциюПолей(СтрокаОбъекта, ОбъектМД, ТипКорня, ИмяКоллекции, ПредставлениеКоллекции)

	Коллекция = ПолучитьКоллекциюОбъектаМетаданных(ОбъектМД, ИмяКоллекции);
	Если Коллекция = Неопределено Тогда
		Возврат;
	КонецЕсли;

	КартинкаКол = КартинкаКоллекции(ИмяКоллекции);
	СтрокаКоллекции = ДобавитьСтрокуДерева(СтрокаОбъекта.Строки, ПредставлениеКоллекции, "", Ложь, "");
	СтрокаКоллекции.Картинка = КартинкаКол;
	ЕстьЛистья = Ложь;

	Для Каждого ПолеМД Из Коллекция Цикл
		Если Не ЭтоПоддерживаемыйТипПоля(ПолеМД) Тогда
			Продолжить;
		КонецЕсли;
		Если ИмяКоллекции = "СтандартныеРеквизиты"
			И (ПолеМД.Имя = "Ссылка" Или ПолеМД.Имя = "ИмяПредопределенныхДанных") Тогда
			Продолжить;
		КонецЕсли;
		ЕстьЛистья = Истина;
		НоваяСтрока = ДобавитьСтрокуДерева(
			СтрокаКоллекции.Строки,
			ПолеМД.Имя,
			ТипКорня + "." + ОбъектМД.Имя + "." + ПолеМД.Имя,
			Истина,
			СтрокаТипаПоля(ПолеМД));
		НоваяСтрока.Картинка = КартинкаКол;
		НоваяСтрока.КлассТипа = КлассТипаПоля(ПолеМД);
	КонецЦикла;

	Если Не ЕстьЛистья Тогда
		СтрокаОбъекта.Строки.Удалить(СтрокаКоллекции);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДобавитьТабличныеЧасти(СтрокаОбъекта, ОбъектМД, ТипКорня)

	КоллекцияТЧ = ПолучитьКоллекциюОбъектаМетаданных(ОбъектМД, "ТабличныеЧасти");
	Если КоллекцияТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;

	КартинкаТЧ = БиблиотекаКартинок.ВложеннаяТаблица;
	КартинкаРекв = КартинкаКоллекции("Реквизиты");
	СтрокаТЧКоллекции = ДобавитьСтрокуДерева(СтрокаОбъекта.Строки, "Табличные части", "", Ложь, "");
	СтрокаТЧКоллекции.Картинка = КартинкаТЧ;
	ЕстьТЧ = Ложь;

	Для Каждого ТабличнаяЧастьМД Из КоллекцияТЧ Цикл
		СтрокаТЧ = ДобавитьСтрокуДерева(СтрокаТЧКоллекции.Строки, ТабличнаяЧастьМД.Имя, "", Ложь, "");
		СтрокаТЧ.Картинка = КартинкаТЧ;
		КоллекцияРеквизитов = ПолучитьКоллекциюОбъектаМетаданных(ТабличнаяЧастьМД, "Реквизиты");
		Если КоллекцияРеквизитов = Неопределено Тогда
			СтрокаТЧКоллекции.Строки.Удалить(СтрокаТЧ);
			Продолжить;
		КонецЕсли;
		СтрокаРеквизитов = ДобавитьСтрокуДерева(СтрокаТЧ.Строки, "Реквизиты", "", Ложь, "");
		СтрокаРеквизитов.Картинка = КартинкаРекв;
		ЕстьРеквизиты = Ложь;
		Для Каждого ПолеМД Из КоллекцияРеквизитов Цикл
			Если Не ЭтоПоддерживаемыйТипПоля(ПолеМД) Тогда
				Продолжить;
			КонецЕсли;
			ЕстьРеквизиты = Истина;
			НоваяСтрока = ДобавитьСтрокуДерева(
				СтрокаРеквизитов.Строки,
				ПолеМД.Имя,
				ТипКорня + "." + ОбъектМД.Имя + "." + ТабличнаяЧастьМД.Имя + "." + ПолеМД.Имя,
				Истина,
				СтрокаТипаПоля(ПолеМД));
			НоваяСтрока.Картинка = КартинкаРекв;
			НоваяСтрока.КлассТипа = КлассТипаПоля(ПолеМД);
		КонецЦикла;
		Если ЕстьРеквизиты Тогда
			ЕстьТЧ = Истина;
		Иначе
			СтрокаТЧ.Строки.Удалить(СтрокаРеквизитов);
			СтрокаТЧКоллекции.Строки.Удалить(СтрокаТЧ);
		КонецЕсли;
	КонецЦикла;

	Если Не ЕстьТЧ Тогда
		СтрокаОбъекта.Строки.Удалить(СтрокаТЧКоллекции);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ДобавитьСтрокуДерева(СтрокиДерева, ПредставлениеСтроки, ПолноеИмяСтроки, ЭтоЛист, ТипЗначения)

	НоваяСтрока = СтрокиДерева.Добавить();
	НоваяСтрока.Использовать = 0;
	НоваяСтрока.Представление = ПредставлениеСтроки;
	НоваяСтрока.Анонимизировать = "";
	НоваяСтрока.ПолноеИмя = ПолноеИмяСтроки;
	НоваяСтрока.ЭтоЛист = ЭтоЛист;
	НоваяСтрока.ТипЗначения = ТипЗначения;
	НоваяСтрока.ИспользоватьДляСловаря = Ложь;
	НоваяСтрока.КатегорияТокена = "";
	НоваяСтрока.КлассТипа = "";
	Возврат НоваяСтрока;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьКоллекциюОбъектаМетаданных(ОбъектМД, ИмяКоллекции)

	Попытка
		Возврат Вычислить("ОбъектМД." + ИмяКоллекции);
	Исключение
		Возврат Неопределено;
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция ЭтоПоддерживаемыйТипПоля(ПолеМД)

	Возврат Не ЭтоТолькоБулевоПоле(ПолеМД);

КонецФункции

&НаСервереБезКонтекста
Функция ЭтоТолькоБулевоПоле(ПолеМД)

	Попытка
		КоллекцияТипов = ПолеМД.Тип.Типы();
		Если КоллекцияТипов.Количество() <> 1 Тогда
			Возврат Ложь;
		КонецЕсли;
		Возврат КоллекцияТипов[0] = Тип("Булево");
	Исключение
		Возврат Ложь;
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция СтрокаТипаПоля(ПолеМД)

	Попытка
		КоллекцияТипов = ПолеМД.Тип.Типы();
		Результат = "";
		Для Каждого ТипПоля Из КоллекцияТипов Цикл
			Если Не ПустаяСтрока(Результат) Тогда
				Результат = Результат + ", ";
			КонецЕсли;
			Результат = Результат + Строка(ТипПоля);
		КонецЦикла;
		Возврат Результат;
	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция КлассТипаПоля(ПолеМД)

	// Предопределённый порядок классов для стабильного вывода
	ПорядокКлассов = Новый Массив;
	ПорядокКлассов.Добавить("Строка");
	ПорядокКлассов.Добавить("Число");
	ПорядокКлассов.Добавить("Булево");
	ПорядокКлассов.Добавить("Дата");
	ПорядокКлассов.Добавить("УникальныйИдентификатор");
	ПорядокКлассов.Добавить("ХранилищеЗначения");
	ПорядокКлассов.Добавить("Характеристика");
	ПорядокКлассов.Добавить("Ссылка");

	Попытка
		КоллекцияТипов = ПолеМД.Тип.Типы();
		НайденныеКлассы = Новый Массив; // упорядоченный, без дублей
		Для Каждого ТипПоля Из КоллекцияТипов Цикл
			СтрТип = Строка(ТипПоля);
			Если ТипПоля = Тип("Строка") Тогда
				Класс = "Строка";
			ИначеЕсли ТипПоля = Тип("Число") Тогда
				Класс = "Число";
			ИначеЕсли ТипПоля = Тип("Булево") Тогда
				Класс = "Булево";
			ИначеЕсли ТипПоля = Тип("Дата") Тогда
				Класс = "Дата";
			ИначеЕсли ТипПоля = Тип("УникальныйИдентификатор") Тогда
				Класс = "УникальныйИдентификатор";
			ИначеЕсли ТипПоля = Тип("ХранилищеЗначения") Тогда
				Класс = "ХранилищеЗначения";
			ИначеЕсли Найти(СтрТип, "Характеристика.") > 0 Тогда
				// Тип значения характеристики — отдельное семейство, не ссылка
				Класс = "Характеристика";
			ИначеЕсли Справочники.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или Документы.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или Перечисления.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или ПланыСчетов.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или БизнесПроцессы.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или Задачи.ТипВсеСсылки().СодержитТип(ТипПоля)
				Или ПланыОбмена.ТипВсеСсылки().СодержитТип(ТипПоля) Тогда
				Класс = "Ссылка";
			Иначе
				Продолжить;
			КонецЕсли;
			Если НайденныеКлассы.Найти(Класс) = Неопределено Тогда
				НайденныеКлассы.Добавить(Класс);
			КонецЕсли;
		КонецЦикла;

		// Собираем результат в предопределённом порядке
		Результат = "";
		Для Каждого ИмяКласса Из ПорядокКлассов Цикл
			Если НайденныеКлассы.Найти(ИмяКласса) <> Неопределено Тогда
				Если Не ПустаяСтрока(Результат) Тогда
					Результат = Результат + ", ";
				КонецЕсли;
				Результат = Результат + ИмяКласса;
			КонецЕсли;
		КонецЦикла;
		Возврат Результат;
	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции

// ─────────────────────────────────────────────────────────────────────────────────
// ПРИМЕНЕНИЕ ПРАВИЛ К ДЕРЕВУ
// ─────────────────────────────────────────────────────────────────────────────────

&НаСервереБезКонтекста
Процедура ПрименитьТаблицуПравилКДереву(ДеревоПравил, ТаблицаПравил)

	СоответствиеПравил = Новый Соответствие;
	Для Каждого СтрокаПравила Из ТаблицаПравил Цикл
		СоответствиеПравил.Вставить(СтрокаПравила.source_path, Новый Структура(
			"action, use_for_dictionary, token_category",
			СтрокаПравила.action,
			СтрокаПравила.use_for_dictionary,
			СтрокаПравила.token_category));
	КонецЦикла;

	ПрименитьПравилаКСтрокамДерева(ДеревоПравил.Строки, СоответствиеПравил);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПрименитьПравилаКСтрокамДерева(СтрокиДерева, СоответствиеПравил)

	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоЛист Тогда
			Правило = СоответствиеПравил.Получить(СтрокаДерева.ПолноеИмя);
			Если Правило <> Неопределено Тогда
				СтрокаДерева.Использовать = 1;
				СтрокаДерева.Анонимизировать = ?(Правило.action = "keep", "Нет", "Да");
				СтрокаДерева.ИспользоватьДляСловаря = Правило.use_for_dictionary;
				Если ПустаяСтрока(Правило.token_category) Тогда
					СтрокаДерева.КатегорияТокена = ОпределитьКатегориюТокенаЛокально(СтрокаДерева.ПолноеИмя);
				Иначе
					СтрокаДерева.КатегорияТокена = Правило.token_category;
				КонецЕсли;
			Иначе
				СтрокаДерева.Использовать = 0;
				СтрокаДерева.Анонимизировать = "";
				СтрокаДерева.ИспользоватьДляСловаря = Ложь;
				СтрокаДерева.КатегорияТокена = "";
			КонецЕсли;
		ИначеЕсли СтрокаДерева.Строки.Количество() > 0 Тогда
			ПрименитьПравилаКСтрокамДерева(СтрокаДерева.Строки, СоответствиеПравил);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПересчитатьГруппыВДереве(СтрокиДерева)

	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.Строки.Количество() > 0 Тогда
			ПересчитатьГруппыВДереве(СтрокаДерева.Строки);
			СтрокаДерева.Использовать = ВычислитьСостояниеГруппыНаСервере(СтрокаДерева.Строки);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ВычислитьСостояниеГруппыНаСервере(СтрокиДерева)

	ЕстьВключенные = Ложь;
	ЕстьВыключенные = Ложь;
	ЕстьЧастичные = Ложь;

	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.Использовать = 2 Тогда
			ЕстьЧастичные = Истина;
		ИначеЕсли СтрокаДерева.Использовать = 1 Тогда
			ЕстьВключенные = Истина;
		Иначе
			ЕстьВыключенные = Истина;
		КонецЕсли;
	КонецЦикла;

	Если ЕстьЧастичные Или (ЕстьВключенные И ЕстьВыключенные) Тогда
		Возврат 2;
	ИначеЕсли ЕстьВключенные Тогда
		Возврат 1;
	КонецЕсли;

	Возврат 0;

КонецФункции


// ============================================================
// Фильтрация дерева (поиск и "Только отмеченные")
// ============================================================

