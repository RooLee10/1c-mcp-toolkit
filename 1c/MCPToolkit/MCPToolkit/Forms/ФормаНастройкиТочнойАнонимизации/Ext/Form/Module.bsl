&НаСервереБезКонтекста
Функция НайтиСПозиции(ИсходныйТекст, Подстрока, ПозицияНачала = 1)

	Если ПозицияНачала <= 1 Тогда
		Возврат Найти(ИсходныйТекст, Подстрока);
	КонецЕсли;

	ТекстДляПоиска = Сред(ИсходныйТекст, ПозицияНачала);
	ПозицияВПодстроке = Найти(ТекстДляПоиска, Подстрока);
	Если ПозицияВПодстроке = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Возврат ПозицияНачала + ПозицияВПодстроке - 1;

КонецФункции

&НаСервереБезКонтекста
Функция ПрочитатьТиповойXMLПравил(ТекстXML)

	ТаблицаПравил = СоздатьТаблицуПравил();
	ПозицияПоиска = 1;

	Пока Истина Цикл
		ПозицияНачалаСтроки = НайтиСПозиции(ТекстXML, "<row>", ПозицияПоиска);
		Если ПозицияНачалаСтроки = 0 Тогда
			Прервать;
		КонецЕсли;

		ПозицияКонцаСтроки = НайтиСПозиции(ТекстXML, "</row>", ПозицияНачалаСтроки);
		Если ПозицияКонцаСтроки = 0 Тогда
			Прервать;
		КонецЕсли;

		ТекстСтроки = Сред(ТекстXML, ПозицияНачалаСтроки, ПозицияКонцаСтроки - ПозицияНачалаСтроки + СтрДлина("</row>"));
		ПозицияПоиска = ПозицияКонцаСтроки + СтрДлина("</row>");

		ЗначенияСтроки = ИзвлечьЗначенияValueИзXMLСтроки(ТекстСтроки);
		Если ЗначенияСтроки.Количество() < 4 Тогда
			Продолжить;
		КонецЕсли;

		Пометка = СокрЛП(ОчиститьТекстXML(ЗначенияСтроки[0]));
		Если Пометка <> "1" Тогда
			Продолжить;
		КонецЕсли;

		ПутьИсточника = НормализоватьТиповойПутьВCanonical(ОчиститьТекстXML(ЗначенияСтроки[1]));
		Если Не ЭтоLeafPath(ПутьИсточника) Тогда
			Продолжить;
		КонецЕсли;

		ПредставлениеПравила = СокрЛП(ОчиститьТекстXML(ЗначенияСтроки[3]));
		Если ПустаяСтрока(ПредставлениеПравила) Тогда
			ПредставлениеПравила = ИзвлечьPresentationИзValueList(ЗначенияСтроки[2]);
		КонецЕсли;

		Action = "anonymize";
		Если ВРег(ПредставлениеПравила) = ВРег("Не изменять") Или ВРег(ПредставлениеПравила) = ВРег("НеИзменять") Тогда
			Action = "keep";
		КонецЕсли;

		Если Не ПустаяСтрока(ПутьИсточника) Тогда
			НоваяСтрока = ДобавитьИлиЗаменитьПравило(ТаблицаПравил, ПутьИсточника);
			НоваяСтрока.action = Action;
			НоваяСтрока.match_kind = "exact_source";
		КонецЕсли;
	КонецЦикла;

	Возврат ТаблицаПравил;

КонецФункции

&НаСервереБезКонтекста
Функция ИзвлечьЗначенияValueИзXMLСтроки(ТекстСтроки)

	Значения = Новый Массив;
	ПозицияПоиска = 1;

	Пока Истина Цикл
		ПозицияНачала = НайтиСПозиции(ТекстСтроки, "<Value", ПозицияПоиска);
		Если ПозицияНачала = 0 Тогда
			Прервать;
		КонецЕсли;

		ПозицияПослеОткрытия = НайтиСПозиции(ТекстСтроки, ">", ПозицияНачала);
		Если ПозицияПослеОткрытия = 0 Тогда
			Прервать;
		КонецЕсли;

		ПозицияКонца = НайтиСПозиции(ТекстСтроки, "</Value>", ПозицияПослеОткрытия);
		Если ПозицияКонца = 0 Тогда
			Прервать;
		КонецЕсли;

		Значения.Добавить(Сред(ТекстСтроки, ПозицияПослеОткрытия + 1, ПозицияКонца - ПозицияПослеОткрытия - 1));
		ПозицияПоиска = ПозицияКонца + СтрДлина("</Value>");
	КонецЦикла;

	Возврат Значения;

КонецФункции

&НаСервереБезКонтекста
Функция ИзвлечьPresentationИзValueList(ТекстValueList)

	ПозицияНачала = Найти(ТекстValueList, "<presentation>");
	Если ПозицияНачала = 0 Тогда
		Возврат "";
	КонецЕсли;

	ПозицияКонца = НайтиСПозиции(ТекстValueList, "</presentation>", ПозицияНачала);
	Если ПозицияКонца = 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат ОчиститьТекстXML(Сред(ТекстValueList,
		ПозицияНачала + СтрДлина("<presentation>"),
		ПозицияКонца - ПозицияНачала - СтрДлина("<presentation>")));

КонецФункции

&НаСервереБезКонтекста
Функция ОчиститьТекстXML(ТекстXML)

	Результат = Строка(ТекстXML);
	Результат = СтрЗаменить(Результат, "&quot;", """");
	Результат = СтрЗаменить(Результат, "&amp;", "&");
	Результат = СтрЗаменить(Результат, "&lt;", "<");
	Результат = СтрЗаменить(Результат, "&gt;", ">");
	Результат = СтрЗаменить(Результат, "&apos;", "'");
	Возврат СокрЛП(Результат);

КонецФункции

&НаСервереБезКонтекста
Функция НормализоватьТиповойПутьВCanonical(ПутьИсточника)

	Результат = СокрЛП(Строка(ПутьИсточника));
	Результат = СтрЗаменить(Результат, ".СтандартныеРеквизиты.", ".");
	Результат = СтрЗаменить(Результат, ".СтандартныйРеквизит.", ".");
	Результат = СтрЗаменить(Результат, ".Реквизиты.", ".");
	Результат = СтрЗаменить(Результат, ".Реквизит.", ".");
	Результат = СтрЗаменить(Результат, ".Измерения.", ".");
	Результат = СтрЗаменить(Результат, ".Измерение.", ".");
	Результат = СтрЗаменить(Результат, ".Ресурсы.", ".");
	Результат = СтрЗаменить(Результат, ".Ресурс.", ".");
	Результат = СтрЗаменить(Результат, ".ТабличныеЧасти.", ".");
	Результат = СтрЗаменить(Результат, ".ТабличнаяЧасть.", ".");
	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция ЭтоLeafPath(ПутьИсточника)

	Если ПустаяСтрока(ПутьИсточника) Тогда
		Возврат Ложь;
	КонецЕсли;

	ПоследнийСегмент = ПолучитьПоследнийСегментПути(ПутьИсточника);
	Если ПоследнийСегмент = "Реквизиты" Или ПоследнийСегмент = "СтандартныеРеквизиты"
		Или ПоследнийСегмент = "Измерения" Или ПоследнийСегмент = "Ресурсы"
		Или ПоследнийСегмент = "ТабличныеЧасти" Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат КоличествоСегментовПути(ПутьИсточника) >= 2;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьПоследнийСегментПути(ПутьИсточника)

	ПозицияТочки = 0;
	ПозицияПоиска = 1;
	Пока Истина Цикл
		СледующаяПозиция = НайтиСПозиции(ПутьИсточника, ".", ПозицияПоиска);
		Если СледующаяПозиция = 0 Тогда
			Прервать;
		КонецЕсли;
		ПозицияТочки = СледующаяПозиция;
		ПозицияПоиска = СледующаяПозиция + 1;
	КонецЦикла;

	Если ПозицияТочки = 0 Тогда
		Возврат ПутьИсточника;
	КонецЕсли;

	Возврат Сред(ПутьИсточника, ПозицияТочки + 1);

КонецФункции

&НаСервереБезКонтекста
Функция ДобавитьИлиЗаменитьПравило(ТаблицаПравил, SourcePath)

	Для Каждого СтрокаПравила Из ТаблицаПравил Цикл
		Если СтрокаПравила.source_path = SourcePath Тогда
			Возврат СтрокаПравила;
		КонецЕсли;
	КонецЦикла;

	НоваяСтрока = ТаблицаПравил.Добавить();
	НоваяСтрока.source_path = SourcePath;
	Возврат НоваяСтрока;

КонецФункции

&НаСервереБезКонтекста
Функция КоличествоСегментовПути(ПутьИсточника)

	Количество = 1;
	ПозицияПоиска = 1;
	Пока Истина Цикл
		ПозицияТочки = НайтиСПозиции(ПутьИсточника, ".", ПозицияПоиска);
		Если ПозицияТочки = 0 Тогда
			Прервать;
		КонецЕсли;
		Количество = Количество + 1;
		ПозицияПоиска = ПозицияТочки + 1;
	КонецЦикла;

	Возврат Количество;

КонецФункции

