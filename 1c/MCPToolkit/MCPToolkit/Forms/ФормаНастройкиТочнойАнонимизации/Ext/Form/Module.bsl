&НаСервере
Функция ЗагрузитьИзФайлаВФормуНаСервере(ТекстНастроек, РежимЗагрузки)
	СброситьФильтрПередЗагрузкойНаСервере();

	ТаблицаЗагруженныхПравил = ПрочитатьТаблицуПравилИзТекста(ТекстНастроек);
	ТаблицаИтоговыхПравил = ?(РежимЗагрузки = "replace",
		ТаблицаЗагруженныхПравил,
		ОбъединитьТаблицыПравил(СобратьПолныеПравилаДляСохранения(), ТаблицаЗагруженныхПравил));

	Дерево = ПостроитьДеревоПравилИзТаблицыПравилНаСервере(ТаблицаИтоговыхПравил, "Импорт из файла");
	ЗначениеВРеквизитФормы(Дерево, "ДеревоПравил");

	// При полной замене сбрасываем флаг заранее — до парсинга JSON.
	// Это гарантирует сброс даже при XML-импорте (JSON-блок не выполнится).
	Если РежимЗагрузки = "replace" Тогда
		АгрессивнаяАнонимизация = Ложь;
	КонецЕсли;

	// Импорт regex_rules и aggressive_mode — только если ключ присутствует в JSON
	// ВАЖНО: до вызова ОбновитьИсточникНабораНаСервере, чтобы сводка отражала актуальный режим
	Попытка
		ТекстБезBOM = УдалитьBOMИПробелыСлева(ТекстНастроек);
		Если НЕ ПустаяСтрока(ТекстБезBOM) Тогда
			JSONКорень = ПрочитатьJSON2(ТекстБезBOM);
			РегексПравила = Неопределено;
			АгрессивныйРежимВФайле = Неопределено;
			Если ТипЗнч(JSONКорень) = Тип("Структура") Тогда
				JSONКорень.Свойство("regex_rules", РегексПравила);
				JSONКорень.Свойство("aggressive_mode", АгрессивныйРежимВФайле);
			ИначеЕсли ТипЗнч(JSONКорень) = Тип("Соответствие") Тогда
				РегексПравила = JSONКорень["regex_rules"];
				АгрессивныйРежимВФайле = JSONКорень["aggressive_mode"];
			КонецЕсли;
			Если ТипЗнч(РегексПравила) = Тип("Массив") Тогда
				ЗаполнитьТаблицуRegexИзМассива(РегексПравила);
			КонецЕсли;
			Если ТипЗнч(АгрессивныйРежимВФайле) = Тип("Булево") Тогда
				АгрессивнаяАнонимизация = АгрессивныйРежимВФайле;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;

	ОбновитьИсточникНабораНаСервере("Импорт из файла");

	Возврат "";

КонецФункции

&НаСервере
Функция ПрочитатьТаблицуПравилИзТекста(ТекстНастроек)

	ТекстБезBOM = УдалитьBOMИПробелыСлева(ТекстНастроек);
	Если ПустаяСтрока(ТекстБезBOM) Тогда
		Возврат СоздатьТаблицуПравил();
	КонецЕсли;

	ПервыйСимвол = Лев(ТекстБезBOM, 1);
	Если ПервыйСимвол = "{" Или ПервыйСимвол = "[" Тогда
		Возврат ПреобразоватьJSONПравилВТаблицу(ПрочитатьJSON2(ТекстБезBOM));
	ИначеЕсли ПервыйСимвол = "<" Тогда
		Возврат ПрочитатьТиповойXMLПравил(ТекстБезBOM);
	КонецЕсли;

	Попытка
		Возврат ПреобразоватьJSONПравилВТаблицу(ПрочитатьJSON2(ТекстБезBOM));
	Исключение
	КонецПопытки;

	Попытка
		Возврат ПрочитатьТиповойXMLПравил(ТекстБезBOM);
	Исключение
		ВызватьИсключение "Неподдерживаемый формат файла настроек.";
	КонецПопытки;

КонецФункции

&НаСервереБезКонтекста
Функция СформироватьJSONПравилКакСтруктуру(ТаблицаПравил)

	МассивПравил = Новый Массив;
	Для Каждого СтрокаПравила Из ТаблицаПравил Цикл
		МассивПравил.Добавить(Новый Структура(
			"source_path, action, match_kind, use_for_dictionary, token_category",
			СтрокаПравила.source_path,
			СтрокаПравила.action,
			СтрокаПравила.match_kind,
			СтрокаПравила.use_for_dictionary,
			СтрокаПравила.token_category));
	КонецЦикла;

	Возврат Новый Структура("version, rules", 2, МассивПравил);

КонецФункции

&НаСервереБезКонтекста
Функция ПреобразоватьJSONПравилВТаблицу(JSONЗначение)

	ТаблицаПравил = СоздатьТаблицуПравил();
	Если JSONЗначение = Неопределено Тогда
		Возврат ТаблицаПравил;
	КонецЕсли;

	ПравилаJSON = ПолучитьСвойствоИзJSONОбъекта(JSONЗначение, "rules");
	Если ПравилаJSON = Неопределено Тогда
		ВызватьИсключение "Некорректный JSON правил: отсутствует массив rules.";
	КонецЕсли;
	Если ТипЗнч(ПравилаJSON) <> Тип("Массив") Тогда
		ВызватьИсключение "Некорректный JSON правил: rules должен быть массивом.";
	КонецЕсли;

	Для Каждого ЭлементПравила Из ПравилаJSON Цикл
		Если ТипЗнч(ЭлементПравила) <> Тип("Структура") И ТипЗнч(ЭлементПравила) <> Тип("Соответствие") Тогда
			Продолжить;
		КонецЕсли;

		SourcePath = СокрЛП(Строка(ПолучитьСвойствоИзJSONОбъекта(ЭлементПравила, "source_path")));
		Если ПустаяСтрока(SourcePath) Тогда
			Продолжить;
		КонецЕсли;

		Action = СокрЛП(Строка(ПолучитьСвойствоИзJSONОбъекта(ЭлементПравила, "action")));
		MatchKind = СокрЛП(Строка(ПолучитьСвойствоИзJSONОбъекта(ЭлементПравила, "match_kind")));
		UseForDictionary = ПолучитьСвойствоИзJSONОбъекта(ЭлементПравила, "use_for_dictionary");
		TokenCategory = СокрЛП(Строка(ПолучитьСвойствоИзJSONОбъекта(ЭлементПравила, "token_category")));

		НоваяСтрока = ДобавитьИлиЗаменитьПравило(ТаблицаПравил, SourcePath);
		НоваяСтрока.action = ?(Action = "keep", "keep", "anonymize");
		НоваяСтрока.match_kind = ?(ПустаяСтрока(MatchKind), "exact_source", MatchKind);
		НоваяСтрока.use_for_dictionary = ?(ТипЗнч(UseForDictionary) = Тип("Булево"), UseForDictionary, Ложь);
		НоваяСтрока.token_category = TokenCategory;
	КонецЦикла;

	Возврат ТаблицаПравил;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСвойствоИзJSONОбъекта(JSONОбъект, ИмяСвойства)

	Если JSONОбъект = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если ТипЗнч(JSONОбъект) = Тип("Структура") Тогда
		ЗначениеСвойства = Неопределено;
		Если JSONОбъект.Свойство(ИмяСвойства, ЗначениеСвойства) Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	ИначеЕсли ТипЗнч(JSONОбъект) = Тип("Соответствие") Тогда
		Попытка
			Возврат JSONОбъект.Получить(ИмяСвойства);
		Исключение
		КонецПопытки;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

&НаСервереБезКонтекста
Функция ОбъединитьТаблицыПравил(ТекущиеПравила, ЗагруженныеПравила)

	СоответствиеПравил = Новый Соответствие;
	Результат = СоздатьТаблицуПравил();

	Для Каждого СтрокаПравила Из ТекущиеПравила Цикл
		СоответствиеПравил.Вставить(СтрокаПравила.source_path, Новый Структура(
			"action, match_kind, use_for_dictionary, token_category",
			СтрокаПравила.action, СтрокаПравила.match_kind,
			СтрокаПравила.use_for_dictionary, СтрокаПравила.token_category));
	КонецЦикла;

	Для Каждого СтрокаПравила Из ЗагруженныеПравила Цикл
		СоответствиеПравил.Вставить(СтрокаПравила.source_path, Новый Структура(
			"action, match_kind, use_for_dictionary, token_category",
			СтрокаПравила.action, СтрокаПравила.match_kind,
			СтрокаПравила.use_for_dictionary, СтрокаПравила.token_category));
	КонецЦикла;

	Для Каждого ЭлементПравила Из СоответствиеПравил Цикл
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.source_path = ЭлементПравила.Ключ;
		НоваяСтрока.action = ЭлементПравила.Значение.action;
		НоваяСтрока.match_kind = ЭлементПравила.Значение.match_kind;
		НоваяСтрока.use_for_dictionary = ЭлементПравила.Значение.use_for_dictionary;
		НоваяСтрока.token_category = ЭлементПравила.Значение.token_category;
	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервереБезКонтекста
Функция УдалитьBOMИПробелыСлева(ТекстНастроек)

	Результат = ТекстНастроек;
	Если СтрДлина(Результат) > 0 И КодСимвола(Лев(Результат, 1)) = 65279 Тогда
		Результат = Сред(Результат, 2);
	КонецЕсли;

	Пока СтрДлина(Результат) > 0 Цикл
		ПервыйСимвол = Лев(Результат, 1);
		Если ПервыйСимвол = Символы.Таб Или ПервыйСимвол = Символы.ПС Или ПервыйСимвол = Символы.ВК Или ПервыйСимвол = " " Тогда
			Результат = Сред(Результат, 2);
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

