		ЗавершитьСохранение();
		Возврат;
	КонецЕсли;
	Паттерн = МассивПаттернов[Индекс];
	Контекст = Новый Структура("Индекс, Массив", Индекс, МассивПаттернов);
	КомпонентаRegexВалид.НачатьВызовValidatePattern(
