			Данные = ПрочитатьJSON2(ЗначениеJSON);
			МассивПравил = Неопределено;
			Если ТипЗнч(Данные) = Тип("Структура") Тогда
				Данные.Свойство("rules", МассивПравил);
			ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
				МассивПравил = Данные["rules"];
			КонецЕсли;
			Если ТипЗнч(МассивПравил) = Тип("Массив") Тогда
				ЗаполнитьТаблицуRegexИзМассива(МассивПравил);
				Возврат;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	// Если в хранилище ничего нет — загрузить дефолты
	ЗагрузитьRegexПравилаПоУмолчаниюНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьRegexПравилаПоУмолчаниюНаСервере()
	Попытка
		Обработка = РеквизитФормыВЗначение("Объект");
		ДвоичныеДанные = Обработка.ПолучитьМакет("НастройкиRegexПоУмолчанию");
		ИмяФайла = ПолучитьИмяВременногоФайла("json");
		ДвоичныеДанные.Записать(ИмяФайла);
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.Прочитать(ИмяФайла);
		Данные = ПрочитатьJSON2(ТекстовыйДокумент.ПолучитьТекст());
		МассивПравил = Неопределено;
		Если ТипЗнч(Данные) = Тип("Структура") Тогда
			Данные.Свойство("rules", МассивПравил);
		ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
			МассивПравил = Данные["rules"];
		КонецЕсли;
		Если ТипЗнч(МассивПравил) = Тип("Массив") Тогда
			ЗаполнитьТаблицуRegexИзМассива(МассивПравил);
		КонецЕсли;
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуRegexИзМассива(МассивПравил)
	ТаблицаRegexПравил.Очистить();
	Для Каждого Правило Из МассивПравил Цикл
		НоваяСтрока = ТаблицаRegexПравил.Добавить();
		ВклЗнч  = Неопределено;
		ПатЗнч  = Неопределено;
		КатЗнч  = Неопределено;
		ОпиЗнч  = Неопределено;
		Если ТипЗнч(Правило) = Тип("Структура") Тогда
			Правило.Свойство("enabled",     ВклЗнч);
			Правило.Свойство("pattern",     ПатЗнч);
			Правило.Свойство("category",    КатЗнч);
			Правило.Свойство("description", ОпиЗнч);
		ИначеЕсли ТипЗнч(Правило) = Тип("Соответствие") Тогда
			ВклЗнч = Правило["enabled"];
			ПатЗнч = Правило["pattern"];
			КатЗнч = Правило["category"];
			ОпиЗнч = Правило["description"];
		КонецЕсли;
		НоваяСтрока.Включено       = ?(ВклЗнч <> Неопределено, ВклЗнч = Истина, Ложь);
		НоваяСтрока.Шаблон         = ?(ПатЗнч <> Неопределено, Строка(ПатЗнч), "");
		НоваяСтрока.КатегорияТокена = ?(КатЗнч <> Неопределено, Строка(КатЗнч), "STR");
		НоваяСтрока.Описание       = ?(ОпиЗнч <> Неопределено, Строка(ОпиЗнч), "");
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура СохранитьRegexПравилаВБазуНаСервере()
	Попытка
		МассивПравил = Новый Массив;
		Для Каждого Стр Из ТаблицаRegexПравил Цикл
			МассивПравил.Добавить(Новый Структура("enabled, pattern, category, description",
				Стр.Включено, Стр.Шаблон, Стр.КатегорияТокена, Стр.Описание));
		КонецЦикла;
		ДанныеJSON = ЗаписатьJSON2(Новый Структура("version, rules", 1, МассивПравил));
		ХранилищеОбщихНастроек.Сохранить("ExecuteQueryRegexRules.v1", "rules", ДанныеJSON);
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
Функция МодальностьЗапрещена()
	Попытка
		Возврат НЕ Вычислить(
			"Метаданные.НайтиПоПолномуИмени(""Конфигурация"").РежимИспользованияМодальности = ""Использовать""");
	Исключение
		Возврат Ложь; // старая платформа — свойство недоступно, считаем модальность разрешённой
	КонецПопытки;
КонецФункции
