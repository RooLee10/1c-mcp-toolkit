Процедура СобратьПравилаИзСтрокДерева(СтрокиДерева, ТаблицаПравил)

	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоЛист И СтрокаДерева.Использовать = 1 Тогда
			НоваяСтрока = ТаблицаПравил.Добавить();
			НоваяСтрока.source_path = СтрокаДерева.ПолноеИмя;
			НоваяСтрока.action = ?(СтрокаДерева.Анонимизировать = "Нет", "keep", "anonymize");
			НоваяСтрока.match_kind = "exact_source";
		КонецЕсли;
		Если СтрокаДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			СобратьПравилаИзСтрокДерева(СтрокаДерева.ПолучитьЭлементы(), ТаблицаПравил);
		КонецЕсли;
	КонецЦикла;

