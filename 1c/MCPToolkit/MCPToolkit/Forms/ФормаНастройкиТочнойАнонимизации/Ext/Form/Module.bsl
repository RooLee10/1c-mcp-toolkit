&НаСервере
Процедура СобратьПравилаИзСтрокДереваНаСервере(СтрокиДерева, ТаблицаПравил)

	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.ЭтоЛист И СтрокаДерева.Использовать = 1 Тогда
			НоваяСтрока = ТаблицаПравил.Добавить();
			НоваяСтрока.source_path = СтрокаДерева.ПолноеИмя;
			НоваяСтрока.action = ?(СтрокаДерева.Анонимизировать = "Нет", "keep", "anonymize");
			НоваяСтрока.match_kind = "exact_source";
			// Защита типа: use_for_dictionary разрешён только для строковых полей
			ИспользоватьДляСловаря = СтрокаДерева.ИспользоватьДляСловаря;
			Если ИспользоватьДляСловаря И Найти(СтрокаДерева.ТипЗначения, "Строка") = 0 Тогда
				ИспользоватьДляСловаря = Ложь;
			КонецЕсли;
			НоваяСтрока.use_for_dictionary = ИспользоватьДляСловаря;
			НоваяСтрока.token_category = СтрокаДерева.КатегорияТокена;
		КонецЕсли;
		Если СтрокаДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			СобратьПравилаИзСтрокДереваНаСервере(СтрокаДерева.ПолучитьЭлементы(), ТаблицаПравил);
		КонецЕсли;
