Функция ПодготовитьТекстПравилДляФайлаНаСервере()

	ОсновнаяСтруктура = СформироватьJSONПравилКакСтруктуру(СобратьПолныеПравилаДляСохранения());

	// Добавить regex_rules в экспорт
	МассивRegex = Новый Массив;
	Для Каждого Стр Из ТаблицаRegexПравил Цикл
		МассивRegex.Добавить(Новый Структура("enabled, pattern, category, description",
			Стр.Включено, Стр.Шаблон, Стр.КатегорияТокена, Стр.Описание));
	КонецЦикла;
	ОсновнаяСтруктура.Вставить("regex_rules", МассивRegex);
	ОсновнаяСтруктура.Вставить("aggressive_mode", АгрессивнаяАнонимизация);

	Возврат ЗаписатьJSON2(ОсновнаяСтруктура);

